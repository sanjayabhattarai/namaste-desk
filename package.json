{
  "name": "namaste-desk",
  "version": "0.1.0",
  "description": "A modern hotel reception management system with room booking, guest check-in, billing, and receipt management.",
  "author": "Namaste Desk Team",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev:desktop": "npm run rebuild:electron",
    "rebuild:electron": "electron-builder install-app-deps",
    "dev:desktop": "concurrently -k \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "build": "next build",
    "prebuild": "prisma generate",
    "predist": "prisma generate",
    "dist": "next build && electron-builder",
    "start": "next start",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@supabase/supabase-js": "^2.104.0",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "electron-is-dev": "^3.0.1",
    "electron-serve": "^3.0.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "to-ico": "^1.1.5",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "build": {
  "appId": "com.namastedesk.app",
  "productName": "Namaste Desk",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.js",
    "public/**/*",
    "out/**/*",
    "generated/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "asar": true,
  "asarUnpack": [
    "**/*.node",
    "generated/**/*",
    "node_modules/better-sqlite3/**/*",
    "node_modules/.prisma/**/*",
    "node_modules/@prisma/client/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/namaste-template.db",
      "to": "namaste-template.db"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
  }
  }
  
